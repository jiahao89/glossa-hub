# ====================================
# GlossaHub 环境变量配置模板
# ====================================
# 复制此文件为 .env 并填写实际值

# ---- 后端 (server.cjs) ----
# 数据库连接 (留空则使用本地 SQLite)
# Supabase 格式: postgresql://postgres.[项目名]:[密码]@aws-0-[区域].pooler.supabase.com:6543/postgres
DATABASE_URL=

# JWT 密钥 (生产环境必填，建议 32+ 位随机字符串)
# 生成方法: openssl rand -hex 32
JWT_SECRET=

# CORS 白名单 (逗号分隔，填入前端域名)
# 本地开发: http://localhost:5173
# Vercel 部署: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# 服务端口 (Render 会自动注入 PORT)
PORT=3001

# ---- 前端 (Vite) ----
# 后端 API 地址 (仅生产环境需要配置)
# 本地开发留空 (走 Vite proxy)
# Vercel 部署填入 Render 后端地址: https://your-backend.onrender.com
VITE_API_BASE_URL=
